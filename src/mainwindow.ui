<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>960</width><height>640</height></rect>
  </property>
  <property name="windowTitle">
   <string>EEEE2076 VR Viewer</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">

    <!-- 主体区域:TreeView + VTK窗口 -->
    <item>
     <layout class="QHBoxLayout" name="horizontalLayout">
      <item>
       <widget class="QTreeView" name="treeView">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Fixed" vsizetype="Expanding">
          <horstretch>0</horstretch><verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="maximumSize">
         <size><width>200</width><height>16777215</height></size>
        </property>
        <property name="contextMenuPolicy">
         <enum>Qt::ContextMenuPolicy::ActionsContextMenu</enum>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QVTKOpenGLNativeWidget" name="widget" native="true">
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
          <horstretch>0</horstretch><verstretch>0</verstretch>
         </sizepolicy>
        </property>
       </widget>
      </item>
     </layout>
    </item>

    <!-- 滤镜控制行 -->
    <item>
     <layout class="QHBoxLayout" name="filterLayout">
      <item>
       <widget class="QLabel" name="labelFilters">
        <property name="text"><string>Filters:</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxClip">
        <property name="text"><string>Clip</string></property>
        <property name="toolTip"><string>Apply vtkClipDataSet to selected part (x=0 plane)</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxShrink">
        <property name="text"><string>Shrink</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxSmooth">
        <property name="text"><string>Smooth</string></property>
        <property name="toolTip"><string>Laplacian smoothing (20 iterations)</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxDecimate">
        <property name="text"><string>Decimate</string></property>
        <property name="toolTip"><string>Reduce polygon count by 90%</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxElevation">
        <property name="text"><string>Elevation</string></property>
        <property name="toolTip"><string>Colour by Z-height (rainbow)</string></property>
       </widget>
      </item>
      <item>
       <widget class="QCheckBox" name="checkBoxSlice">
        <property name="text"><string>Slice</string></property>
        <property name="toolTip"><string>Show cross-section slices (creative feature) for selected part</string></property>
       </widget>
      </item>
      <item>
       <spacer name="filterSpacer">
        <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
        <property name="sizeHint" stdset="0">
         <size><width>40</width><height>20</height></size>
        </property>
       </spacer>
      </item>
     </layout>
    </item>

    <!-- 光照强度控制行(创意功能:VR运行时实时调节主光源亮度)-->
    <item>
     <layout class="QHBoxLayout" name="lightLayout">
      <item>
       <widget class="QLabel" name="labelLight">
        <property name="text"><string>Light:</string></property>
        <property name="toolTip"><string>Adjust main light intensity in VR scene</string></property>
       </widget>
      </item>
      <item>
       <widget class="QSlider" name="sliderLightIntensity">
        <property name="minimum"><number>0</number></property>
        <property name="maximum"><number>100</number></property>
        <property name="value"><number>40</number></property>
        <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
        <property name="tickPosition"><enum>QSlider::TickPosition::TicksBelow</enum></property>
        <property name="tickInterval"><number>10</number></property>
        <property name="toolTip"><string>Drag to change VR light intensity in real time</string></property>
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
          <horstretch>0</horstretch><verstretch>0</verstretch>
         </sizepolicy>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="labelLightValue">
        <property name="text"><string>80%</string></property>
        <property name="minimumSize"><size><width>35</width><height>0</height></size></property>
        <property name="alignment"><set>Qt::AlignmentFlag::AlignRight|Qt::AlignmentFlag::AlignVCenter</set></property>
       </widget>
      </item>
     </layout>
    </item>

   </layout>
  </widget>

  <widget class="QStatusBar" name="statusbar"/>

  <!-- 工具栏:文字按钮,File/Item 为下拉菜单 -->
  <widget class="QToolBar" name="toolBar">
   <property name="windowTitle"><string>toolBar</string></property>
   <property name="toolButtonStyle"><enum>Qt::ToolButtonStyle::ToolButtonTextOnly</enum></property>
   <attribute name="toolBarArea"><enum>TopToolBarArea</enum></attribute>
   <attribute name="toolBarBreak"><bool>false</bool></attribute>
   <addaction name="separator"/>
   <addaction name="actionStart_VR"/>
   <addaction name="actionStop_VR"/>
   <addaction name="separator"/>
   <addaction name="actionReset_View"/>
   <addaction name="separator"/>
   <addaction name="actionStart_Rotate"/>
   <addaction name="actionStop_Rotate"/>
  </widget>

  <!-- ===== Actions ===== -->

  <action name="actionOpen_File">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/fileopen.png</normaloff>:/icon/Icons/fileopen.png
    </iconset>
   </property>
   <property name="text"><string>Open File...</string></property>
   <property name="toolTip"><string>Load a single STL file (Ctrl+O)</string></property>
   <property name="shortcut"><string>Ctrl+O</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionOpen_Directory">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/filesave.png</normaloff>:/icon/Icons/filesave.png
    </iconset>
   </property>
   <property name="text"><string>Open Directory...</string></property>
   <property name="toolTip"><string>Load all STL files from a directory (Ctrl+Shift+O)</string></property>
   <property name="shortcut"><string>Ctrl+Shift+O</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionAdd_Item">
   <property name="text"><string>Add Item</string></property>
   <property name="toolTip"><string>Add a single STL as child of selected node</string></property>
   <property name="shortcut"><string>Ctrl+A</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionItem_Options">
   <property name="text"><string>Item Options...</string></property>
   <property name="toolTip"><string>Edit name, colour and visibility of selected part</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionDelete_Node">
   <property name="text"><string>Delete Node</string></property>
   <property name="toolTip"><string>Delete selected node and remove from VR scene</string></property>
   <property name="shortcut"><string>Del</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionStart_VR">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/startVR.png</normaloff>:/icon/Icons/startVR.png
    </iconset>
   </property>
   <property name="text"><string>Start VR</string></property>
   <property name="toolTip"><string>Launch VR render thread (F5)</string></property>
   <property name="shortcut"><string>F5</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionStop_VR">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/stopVR.png</normaloff>:/icon/Icons/stopVR.png
    </iconset>
   </property>
   <property name="text"><string>Stop VR</string></property>
   <property name="toolTip"><string>Stop VR render thread (F6)</string></property>
   <property name="shortcut"><string>F6</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionSet_View">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/filesave.png</normaloff>:/icon/Icons/filesave.png
    </iconset>
   </property>
   <property name="text"><string>Set View</string></property>
   <property name="toolTip"><string>Cycle model orientation: Front / Top / Right Side / Isometric (F9)</string></property>
   <property name="shortcut"><string>F9</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionViewFront">
   <property name="text"><string>Front</string></property>
   <property name="toolTip"><string>Set model to Front view</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionViewTop">
   <property name="text"><string>Top</string></property>
   <property name="toolTip"><string>Set model to Top view</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionViewRight">
   <property name="text"><string>Right Side</string></property>
   <property name="toolTip"><string>Set model to Right Side view</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionViewIso">
   <property name="text"><string>Isometric</string></property>
   <property name="toolTip"><string>Set model to Isometric view</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionReset_View">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/print.png</normaloff>:/icon/Icons/print.png
    </iconset>
   </property>
   <property name="text"><string>Reset View</string></property>
   <property name="toolTip"><string>Reset camera to default position (F7)</string></property>
   <property name="shortcut"><string>F7</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionStart_Rotate">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/help.png</normaloff>:/icon/Icons/help.png
    </iconset>
   </property>
   <property name="text"><string>Start Rotate</string></property>
   <property name="toolTip"><string>Start auto-rotation animation (F8)</string></property>
   <property name="shortcut"><string>F8</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionStop_Rotate">
   <property name="icon">
    <iconset resource="icons.qrc">
     <normaloff>:/icon/Icons/help.png</normaloff>:/icon/Icons/help.png
    </iconset>
   </property>
   <property name="text"><string>Stop Rotate</string></property>
   <property name="toolTip"><string>Stop auto-rotation animation (F9)</string></property>
   <property name="shortcut"><string>Shift+F8</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <!-- 右键菜单专用 actions -->
  <action name="actionToggleClip">
   <property name="text"><string>Toggle Clip</string></property>
   <property name="toolTip"><string>Toggle vtkClipDataSet filter on this part only</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionToggleShrink">
   <property name="text"><string>Toggle Shrink</string></property>
   <property name="toolTip"><string>Toggle vtkShrinkFilter on this part only</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionToggleSmooth">
   <property name="text"><string>Toggle Smooth</string></property>
   <property name="toolTip"><string>Toggle Laplacian smooth on this part only</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionToggleDecimate">
   <property name="text"><string>Toggle Decimate</string></property>
   <property name="toolTip"><string>Toggle polygon reduction on this part only</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

  <action name="actionToggleElevation">
   <property name="text"><string>Toggle Elevation</string></property>
   <property name="toolTip"><string>Toggle Z-height colour on this part only</string></property>
   <property name="menuRole"><enum>QAction::MenuRole::NoRole</enum></property>
  </action>

 </widget>
