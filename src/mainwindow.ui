  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #080c14; }
QWidget#centralwidget { background-color: #080c14; }
QTreeView {
    background-color: #0d1420; color: #c8d8f0;
    border: none; border-right: 1px solid #1e3050;
    font-family: Consolas, monospace; font-size: 12px;
    selection-background-color: #1a3a6e; selection-color: #7eb8f7;
    outline: none; padding: 4px 0px;
}
QTreeView::item { padding: 4px 6px; border-bottom: 1px solid #111c2e; min-height: 22px; }
QTreeView::item:hover { background-color: #132040; color: #a0c8ff; }
QTreeView::item:selected { background-color: #1a3a6e; color: #7eb8f7; border-left: 2px solid #3b82f6; }
QTreeView::branch { background-color: #0d1420; }
QVTKOpenGLNativeWidget { border: 1px solid #1e3050; }
QWidget#filterStrip { background-color: #0a1020; border-top: 1px solid #1e3050; border-bottom: 1px solid #1e3050; }
QWidget#lightStrip { background-color: #080e1a; border-bottom: 1px solid #141f30; }
QLabel { color: #4a6fa0; font-family: "Segoe UI", sans-serif; font-size: 11px; font-weight: 600; background: transparent; }
QLabel#labelFilters { color: #3b82f6; font-size: 10px; font-weight: 700; letter-spacing: 2px; padding: 0px 8px; min-width: 52px; }
QLabel#labelLight { color: #3b82f6; font-size: 10px; font-weight: 700; letter-spacing: 2px; padding: 0px 8px; min-width: 52px; }
QLabel#labelLightValue { color: #7eb8f7; font-family: Consolas, monospace; font-size: 12px; font-weight: 700; min-width: 42px; padding-right: 8px; }
QCheckBox { color: #7a9cc8; font-family: "Segoe UI", sans-serif; font-size: 12px; font-weight: 500; spacing: 6px; padding: 3px 10px 3px 4px; background: transparent; border: none; }
QCheckBox:hover { color: #a0c8ff; }
QCheckBox:checked { color: #60a5fa; font-weight: 600; }
QCheckBox::indicator { width: 14px; height: 14px; border: 1px solid #2a4070; border-radius: 3px; background-color: #0d1a2e; }
QCheckBox::indicator:hover { border-color: #3b82f6; background-color: #0f2040; }
QCheckBox::indicator:checked { background-color: #1d4ed8; border-color: #3b82f6; }
QSlider::groove:horizontal { height: 3px; background: #1a2e50; border-radius: 2px; margin: 0px 2px; }
QSlider::sub-page:horizontal { background: #3b82f6; border-radius: 2px; height: 3px; }
QSlider::add-page:horizontal { background: #1a2e50; border-radius: 2px; height: 3px; }
QSlider::handle:horizontal { background: #60a5fa; border: 2px solid #1d4ed8; width: 14px; height: 14px; margin: -6px 0px; border-radius: 7px; }
QSlider::handle:horizontal:hover { background: #93c5fd; border-color: #3b82f6; }
QToolBar { background-color: #0a1020; border-bottom: 1px solid #1e3050; spacing: 2px; padding: 4px 8px; }
QToolBar::separator { background: #1e3050; width: 1px; margin: 4px 6px; }
QToolButton { background: transparent; color: #7a9cc8; border: 1px solid transparent; border-radius: 5px; padding: 4px 12px; font-family: "Segoe UI", sans-serif; font-size: 12px; font-weight: 500; min-width: 60px; }
QToolButton:hover { background-color: #132040; border-color: #2a4878; color: #a0c8ff; }
QToolButton:pressed { background-color: #0f1a30; border-color: #3b82f6; color: #60a5fa; }
QStatusBar { background-color: #060a10; color: #3a5a8a; border-top: 1px solid #141f30; font-family: Consolas, monospace; font-size: 11px; padding: 2px 8px; }
QStatusBar::item { border: none; }
QScrollBar:vertical { background: #0a1020; width: 8px; border: none; }
QScrollBar::handle:vertical { background: #1e3050; border-radius: 4px; min-height: 24px; }
QScrollBar::handle:vertical:hover { background: #2a4878; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
QScrollBar:horizontal { background: #0a1020; height: 8px; border: none; }
QScrollBar::handle:horizontal { background: #1e3050; border-radius: 4px; min-width: 24px; }
QScrollBar::handle:horizontal:hover { background: #2a4878; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0px; }
QHeaderView { background-color: #0a1020; border: none; }
QHeaderView::section { background-color: #0a1020; color: #3b82f6; font-family: "Segoe UI", sans-serif; font-size: 10px; font-weight: 700; letter-spacing: 1.5px; padding: 5px 8px; border: none; border-bottom: 1px solid #1e3050; border-right: 1px solid #111c2e; }
QMenu { background-color: #0d1a2e; color: #c8d8f0; border: 1px solid #1e3050; border-radius: 6px; padding: 4px; font-family: "Segoe UI", sans-serif; font-size: 12px; }
QMenu::item { padding: 6px 18px 6px 10px; border-radius: 4px; }
QMenu::item:selected { background-color: #1a3a6e; color: #7eb8f7; }
QMenu::separator { height: 1px; background: #1e3050; margin: 3px 0px; }
