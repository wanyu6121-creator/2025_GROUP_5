  <property name="styleSheet">
   <string notr="true">
QDialog { background-color: #0d1420; color: #c8d8f0; font-family: "Segoe UI", sans-serif; font-size: 13px; }
QLabel { color: #4a6fa0; background: transparent; font-size: 11px; font-weight: 600; }
QLineEdit { background-color: #080e1a; color: #c8d8f0; border: 1px solid #1e3050; border-radius: 5px; padding: 6px 10px; font-size: 13px; selection-background-color: #1d4ed8; }
QLineEdit:focus { border-color: #3b82f6; background-color: #0a1220; }
QLineEdit:hover { border-color: #2a4878; }
QSpinBox { background-color: #080e1a; color: #c8d8f0; border: 1px solid #1e3050; border-radius: 5px; padding: 5px 8px; font-size: 13px; font-family: Consolas, monospace; min-width: 72px; }
QSpinBox:focus { border-color: #3b82f6; }
QSpinBox:hover { border-color: #2a4878; }
QSpinBox::up-button { background: #111c2e; border: none; width: 18px; border-top-right-radius: 5px; }
QSpinBox::down-button { background: #111c2e; border: none; width: 18px; border-bottom-right-radius: 5px; }
QSpinBox::up-button:hover, QSpinBox::down-button:hover { background: #1a3060; }
QPushButton#pickColourButton { background: transparent; color: #60a5fa; border: 1px solid #1d4ed8; border-radius: 5px; padding: 5px 14px; font-size: 12px; font-weight: 600; min-width: 100px; }
QPushButton#pickColourButton:hover { background-color: #0f2040; border-color: #3b82f6; color: #93c5fd; }
QPushButton#pickColourButton:pressed { background-color: #1a3060; }
QLabel#colourSwatch { border: 1px solid #2a4878; border-radius: 4px; }
QCheckBox { color: #7a9cc8; font-family: "Segoe UI", sans-serif; font-size: 12px; spacing: 8px; background: transparent; }
QCheckBox:hover { color: #a0c8ff; }
QCheckBox:checked { color: #60a5fa; font-weight: 600; }
QCheckBox::indicator { width: 15px; height: 15px; border: 1px solid #2a4070; border-radius: 3px; background-color: #080e1a; }
QCheckBox::indicator:hover { border-color: #3b82f6; }
QCheckBox::indicator:checked { background-color: #1d4ed8; border-color: #3b82f6; }
QDialogButtonBox QPushButton { background: transparent; color: #4a6fa0; border: 1px solid #1e3050; border-radius: 5px; padding: 6px 20px; font-size: 12px; font-weight: 600; min-width: 70px; }
QDialogButtonBox QPushButton:hover { background-color: #111c2e; color: #c8d8f0; border-color: #2a4878; }
QDialogButtonBox QPushButton[text="OK"] { background-color: #0f2040; color: #60a5fa; border-color: #1d4ed8; }
QDialogButtonBox QPushButton[text="OK"]:hover { background-color: #1a3060; border-color: #3b82f6; color: #93c5fd; }
QFrame#divider { color: #1e3050; background-color: #1e3050; max-height: 1px; border: none; }
   </string>
